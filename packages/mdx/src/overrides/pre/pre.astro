---
import { Icon } from '@iconify/react'
import { cn } from '@explainer/ui'
import { languageIcons, shellLanguages, terminalCommands } from '../../language-icons'

interface Props {
  class?: string
  'data-language'?: string
  'data-label'?: string
  [key: string]: unknown
}

const {
  class: className,
  'data-language': language,
  'data-label': label,
  ...props
} = Astro.props

const lang = (language || '').toLowerCase()
const lbl = (label || '').toLowerCase()

const slotHtml = await Astro.slots.render('default')

let icon = languageIcons[lbl] || languageIcons[lang] || 'mdi:code-tags'

// For shell languages, detect package manager from content
if (shellLanguages.includes(lang)) {
  const text = slotHtml.replace(/<[^>]+>/g, '').trim()
  const match = text.match(/^(\w+)/)
  if (match) {
    const cmd = match[1].toLowerCase()
    if (terminalCommands.includes(cmd) && languageIcons[cmd]) {
      icon = languageIcons[cmd]
    }
  }
}
---

{label ? (
  <div class="code-block group relative my-4 overflow-hidden rounded-lg border bg-background text-sm">
    <div class="code-block-header flex items-center gap-2 border-b bg-background px-4 py-2.5">
      <Icon client:load icon={icon} className="size-4 text-muted-foreground" />
      <span class="font-medium text-muted-foreground">{label}</span>
    </div>
    <div class="relative">
      <pre
        class={cn('overflow-x-auto p-4 text-sm leading-relaxed', className)}
        data-language={language}
        data-label={label}
        {...props}
      ><Fragment set:html={slotHtml} /></pre>
    </div>
  </div>
) : (
  <pre
    class={cn('my-4 overflow-x-auto rounded-lg border bg-muted p-4 text-sm leading-relaxed', className)}
    data-language={language}
    {...props}
  ><Fragment set:html={slotHtml} /></pre>
)}
