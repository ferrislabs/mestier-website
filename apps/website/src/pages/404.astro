---
import Base from '../layouts/base.astro'
import { WebsiteNavbar } from '../components/website-navbar'
import { Footer } from '@explainer/ui'
import { siteConfig } from '../config'

const appUrlOverrides = {
  website: import.meta.env.PUBLIC_WEBSITE_URL,
  docs: import.meta.env.PUBLIC_DOCS_URL,
  blog: import.meta.env.PUBLIC_BLOG_URL,
}
---

<Base title="404 — Page introuvable">
  <WebsiteNavbar appUrlOverrides={appUrlOverrides} client:load transition:persist />

  <main class="flex-1 flex flex-col items-center justify-center px-6 text-center">
    <p class="text-primary text-sm font-semibold tracking-widest uppercase mb-4">404</p>
    <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-4">Page introuvable</h1>
    <p class="text-muted-foreground text-lg max-w-md mb-8">
      Désolé, nous n'avons pas trouvé la page que vous cherchez.
    </p>
    <a
      href="/"
      class="inline-flex items-center justify-center rounded-md bg-primary px-6 py-2.5 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
    >
      Retour à l'accueil
    </a>
  </main>

  <div class="mx-auto max-w-6xl px-6 w-full">
    <Footer config={siteConfig} appUrlOverrides={appUrlOverrides} client:load />
  </div>
</Base>
