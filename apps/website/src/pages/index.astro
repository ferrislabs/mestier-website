---
import Base from '../layouts/base.astro'
import { WebsiteNavbar } from '../components/website-navbar'
import HeroSection from '../components/hero-section.astro'
import ProductPreview from '../components/product-preview.astro'
import SectorsStrip from '../components/sectors-strip.astro'
import FeaturesSection from '../components/features-section.astro'
import PlatformSection from '../components/platform-section.astro'
import HighlightsSection from '../components/highlights-section.astro'
import PerformanceSection from '../components/performance-section.astro'
import UseCasesSection from '../components/usecases-section.astro'
import PricingSection from '../components/pricing-section.astro'
import TestimonialsSection from '../components/testimonials-section.astro'
import FoundersSection from '../components/founders-section.astro'
import CtaSection from '../components/cta-section.astro'
import { Footer } from '@explainer/ui'
import { siteConfig } from '../config'
import { ui } from '../i18n/ui'

const appUrlOverrides = {
  website: import.meta.env.PUBLIC_WEBSITE_URL,
  docs: import.meta.env.PUBLIC_DOCS_URL,
  blog: import.meta.env.PUBLIC_BLOG_URL,
}

// Base markup is authored in French; this map drives the English swap.
const translations = ui.en
const thumbnails = { fr: '/thumbnail.png', en: '/thumbnails/en/thumbnail.png' }
---

<Base
  title="Mestier — ERP & CRM open-source pour artisans et PME"
  description="Devis, factures, clients et stock dans un ERP open-source conçu en Rust. Rapide, fiable et auto-hébergeable."
  thumbnail="/thumbnail.png"
>
  <WebsiteNavbar appUrlOverrides={appUrlOverrides} client:load transition:persist />

  <HeroSection />
  <SectorsStrip />
  <PlatformSection />
  <ProductPreview />
  <FeaturesSection />
  <HighlightsSection />
  <PerformanceSection />
  <UseCasesSection />
  <PricingSection />
  <TestimonialsSection />
  <FoundersSection />
  <CtaSection />

  <div class="mx-auto max-w-6xl px-6">
    <Footer config={siteConfig} appUrlOverrides={appUrlOverrides} client:load />
  </div>
</Base>

<script is:inline define:vars={{ translations, thumbnails }}>
  function detectLocale() {
    const match = document.cookie.match(/(?:^|; )locale=([^;]*)/)
    const cookie = match ? match[1] : null
    if (cookie === 'en' || cookie === 'fr') return cookie

    const browser = (navigator.language || '').split('-')[0]
    if (browser === 'en' || browser === 'fr') return browser
    return 'fr'
  }

  function applyTranslations(e) {
    const locale = (e instanceof CustomEvent && e.detail && e.detail.locale) ? e.detail.locale : detectLocale()
    document.documentElement.lang = locale

    if (locale === 'fr') {
      document.querySelectorAll('[data-t]').forEach(function (el) {
        if (el.dataset.tDefault) el.textContent = el.dataset.tDefault
      })
      return
    }

    document.querySelectorAll('[data-t]').forEach(function (el) {
      const key = el.getAttribute('data-t')
      if (!el.dataset.tDefault) el.dataset.tDefault = el.textContent
      if (translations[key]) el.textContent = translations[key]
    })

    const thumb = thumbnails[locale] || thumbnails['fr']
    document.querySelectorAll('meta[property="og:image"], meta[name="twitter:image"]').forEach(function (el) {
      el.setAttribute('content', thumb)
    })
  }

  applyTranslations()
  document.addEventListener('astro:after-swap', applyTranslations)
  window.addEventListener('locale:change', applyTranslations)
</script>
