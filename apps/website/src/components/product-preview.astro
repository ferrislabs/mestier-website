---
import { Icon } from "@iconify/react";
---

<section class="border-b bg-grid">
  <div class="mx-auto max-w-6xl px-5 py-20 sm:py-24">
    <div class="mx-auto mb-12 max-w-2xl text-center">
      <p class="text-sm font-semibold uppercase tracking-wide text-primary" data-t="preview.label">
        Une interface, pas un tableur
      </p>
      <h2
        class="mt-3 text-4xl font-semibold tracking-tight text-foreground sm:text-5xl"
        data-t="preview.title"
      >
        Votre activité d'un coup d'œil.
      </h2>
    </div>

    <!-- Product mockup -->
    <div class="relative mx-auto max-w-5xl">
      <div class="overflow-hidden rounded-xl border bg-card shadow-2xl shadow-primary/5">
        <!-- Window chrome -->
        <div class="flex items-center gap-2 border-b bg-muted/50 px-4 py-3">
          <span class="size-3 rounded-full bg-foreground/15"></span>
          <span class="size-3 rounded-full bg-foreground/15"></span>
          <span class="size-3 rounded-full bg-foreground/15"></span>
          <div
            class="ml-3 hidden items-center gap-2 rounded-md border bg-background px-3 py-1 text-xs text-muted-foreground sm:flex"
          >
            <Icon icon="mdi:lock-outline" className="size-3" client:load />
            app.mestier.fr / tableau-de-bord
          </div>
        </div>

        <div class="flex">
          <!-- Sidebar -->
          <aside class="hidden w-52 shrink-0 border-r bg-muted/30 p-3 sm:block">
            <div class="flex items-center gap-2 px-2 py-1.5">
              <img src="/logo.svg" alt="" class="size-4" />
              <span class="text-sm font-semibold tracking-tight">Mestier</span>
            </div>
            <nav class="mt-3 space-y-0.5 text-sm">
              <span
                class="flex items-center gap-2.5 rounded-md bg-primary/10 px-2 py-1.5 font-medium text-primary"
              >
                <Icon icon="mdi:view-dashboard-outline" className="size-4" client:load />
                Tableau de bord
              </span>
              <span class="flex items-center gap-2.5 rounded-md px-2 py-1.5 text-muted-foreground">
                <Icon icon="mdi:account-group-outline" className="size-4" client:load />
                Clients
              </span>
              <span class="flex items-center gap-2.5 rounded-md px-2 py-1.5 text-muted-foreground">
                <Icon icon="mdi:file-document-outline" className="size-4" client:load />
                Devis
              </span>
              <span class="flex items-center gap-2.5 rounded-md px-2 py-1.5 text-muted-foreground">
                <Icon icon="mdi:receipt-text-outline" className="size-4" client:load />
                Factures
              </span>
              <span class="flex items-center gap-2.5 rounded-md px-2 py-1.5 text-muted-foreground">
                <Icon icon="mdi:package-variant-closed" className="size-4" client:load />
                Stock
              </span>
            </nav>
          </aside>

          <!-- Main panel -->
          <div class="flex-1 p-5 text-left">
            <div class="grid grid-cols-3 gap-3">
              <div class="rounded-lg border bg-background p-3">
                <p class="text-[11px] uppercase tracking-wider text-muted-foreground">Chiffre d'affaires</p>
                <p class="mt-1 text-xl font-semibold">128 400 €</p>
                <p class="text-xs text-primary">+12,4 % ce mois</p>
              </div>
              <div class="rounded-lg border bg-background p-3">
                <p class="text-[11px] uppercase tracking-wider text-muted-foreground">Devis en cours</p>
                <p class="mt-1 text-xl font-semibold">23</p>
                <p class="text-xs text-muted-foreground">9 en attente</p>
              </div>
              <div class="rounded-lg border bg-background p-3">
                <p class="text-[11px] uppercase tracking-wider text-muted-foreground">Marge moyenne</p>
                <p class="mt-1 text-xl font-semibold">34,8 %</p>
                <p class="text-xs text-primary">+2,1 pts</p>
              </div>
            </div>

            <div class="mt-3 rounded-lg border bg-background">
              <div class="flex items-center justify-between border-b px-3 py-2">
                <span class="text-sm font-medium">Dernières factures</span>
                <span class="rounded-md bg-primary px-2 py-1 text-[11px] font-semibold text-primary-foreground">+ Nouvelle</span>
              </div>
              <div class="divide-y text-sm">
                {[
                  { c: "Menuiserie Laurent", n: "FA-2048", a: "4 320 €", s: "Payée", ok: true },
                  { c: "Atelier Dubois", n: "FA-2047", a: "1 880 €", s: "Envoyée", ok: false },
                  { c: "SARL Toiture Pro", n: "FA-2046", a: "9 150 €", s: "Payée", ok: true },
                ].map((r) => (
                  <div class="flex items-center justify-between px-3 py-2.5">
                    <div class="flex items-center gap-2.5">
                      <span class="flex size-7 items-center justify-center rounded-md bg-primary/10 text-xs font-semibold text-primary">
                        {r.c.slice(0, 2).toUpperCase()}
                      </span>
                      <div>
                        <p class="font-medium leading-tight">{r.c}</p>
                        <p class="text-[11px] text-muted-foreground">{r.n}</p>
                      </div>
                    </div>
                    <div class="flex items-center gap-3">
                      <span class="font-medium">{r.a}</span>
                      <span
                        class:list={[
                          "rounded-full px-2 py-0.5 text-[11px] font-medium",
                          r.ok ? "bg-primary/10 text-primary" : "bg-muted text-muted-foreground",
                        ]}
                      >
                        {r.s}
                      </span>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
