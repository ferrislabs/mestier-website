---
import { Icon } from "@iconify/react";

const sectors = [
  { icon: "mdi:rocket-launch-outline", label: "Startups" },
  { icon: "mdi:palette-swatch-outline", label: "Agences" },
  { icon: "mdi:cloud-outline", label: "Tech & SaaS" },
  { icon: "mdi:storefront-outline", label: "Commerce" },
  { icon: "mdi:account-tie-outline", label: "Services" },
  { icon: "mdi:hammer-screwdriver", label: "Artisanat" },
];
---

<section class="border-b">
  <div class="mx-auto max-w-6xl px-5 py-12">
    <p
      class="text-center text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground"
      data-t="sectors.label"
    >
      Adopté par les startups, agences, PME et artisans
    </p>
    <div class="mt-7 flex flex-wrap items-center justify-center gap-x-3 gap-y-3">
      {
        sectors.map((s) => (
          <span class="inline-flex items-center gap-2 rounded-full border bg-card px-4 py-2 text-sm font-medium text-foreground/80">
            <Icon icon={s.icon} className="size-4 text-primary" client:load />
            {s.label}
          </span>
        ))
      }
    </div>
  </div>
</section>
