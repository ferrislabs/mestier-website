---
const founders = [
  { name: "Nathaël Bonnal", photo: "/members/nathael.jpeg" },
  { name: "Baptiste Parmantier", photo: "/members/baptiste.jpeg" },
  { name: "Mathieu Bonnal", photo: "/members/mathieu.jpeg" },
];
---

<section id="founders" class="border-b">
  <div class="mx-auto max-w-6xl px-5 py-20 sm:py-28">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-wide text-primary" data-t="founders.label">
        L'équipe
      </p>
      <h2
        class="mt-3 text-4xl font-semibold tracking-tight text-foreground sm:text-5xl"
        data-t="founders.title"
      >
        Les membres fondateurs.
      </h2>
      <p class="mt-4 text-lg text-muted-foreground" data-t="founders.description">
        Mestier est porté par trois fondateurs qui construisent l'outil qu'ils
        auraient voulu avoir.
      </p>
    </div>

    <div class="mt-12 grid grid-cols-1 gap-px overflow-hidden border bg-border sm:grid-cols-3">
      {
        founders.map((f) => (
          <div class="bg-card">
            <img
              src={f.photo}
              alt={f.name}
              loading="lazy"
              class="aspect-square w-full object-cover"
            />
            <div class="p-6">
              <h3 class="text-lg font-semibold text-foreground">{f.name}</h3>
              <p class="mt-1 text-sm text-muted-foreground" data-t="founders.role">
                Co-fondateur
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
